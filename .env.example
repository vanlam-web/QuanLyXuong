# Copy to .env or set these as Windows environment variables on the running machine.

KIOT_USERNAME=Bot
KIOT_PASSWORD=change-me
AUTO_CRM_ZALO_GROUP_ID=group:change-me
SERVER_ZALO_TARGET=group:change-me
DASHBOARD_ADMIN_PIN=change-me

# Shared QuanLyXuong config. Defaults match current production values if unset.
QLX_RUNTIME_MODE=v2
QLX_ENABLE_AUTO_CRM=0
QLX_ENABLE_SERVER_ZALO=0
QLX_DB_DIR=C:\QuanLyXuong\Data
QLX_BASE_DATA_CRM=C:\QuanLyXuong\Data_Auto_CRM
QLX_OPENCLAW_PATH=C:\Users\Admin\AppData\Roaming\npm\openclaw.cmd
QLX_API_SERVER_URL=http://192.168.1.104:8000/api/log_event
QLX_AUTO_CRM_WAKE_URL=http://127.0.0.1:8001/wake_up
QLX_SERVER_BROADCAST_URL=http://127.0.0.1:8000/api/broadcast
QLX_SERVER_HOST=0.0.0.0
QLX_SERVER_PORT=8000
QLX_DASHBOARD_HOST=0.0.0.0
QLX_DASHBOARD_PORT=5000
QLX_AUTO_CRM_HOST=127.0.0.1
QLX_AUTO_CRM_PORT=8001
QLX_NAS_CLIENT_EXE_PATH=\\192.168.1.188\AI\Tools\dist\QuanLyXuong.exe
QLX_NAS_SERVER_EXE_PATH=\\192.168.1.188\AI\Tools\dist\server.exe
QLX_NAS_DASHBOARD_EXE_PATH=\\192.168.1.188\AI\Tools\dist\Dashboard.exe
QLX_NAS_CRM_EXE_PATH=\\192.168.1.188\AI\Tools\dist\Auto_CRM.exe
QLX_KIOT_URL=https://quangcaoinvanlam.kiotviet.vn/

# Optional workstation hostname aliases. Format: machine=alias1,alias2;machine=alias3
# Example: QLX_MACHINE_ALIASES=inbat=INBAT-PC,PRINT-01;indecal=DECAL-PC;cnc=CNC-BACKUP
QLX_MACHINE_ALIASES=

# QCVL bridge defaults to dry-run. Set QCVL_BRIDGE_DRY_RUN=0 only after QCVL endpoint is ready.
QCVL_BRIDGE_DRY_RUN=1
QCVL_API_BASE_URL=http://127.0.0.1:3100
QCVL_API_TOKEN=
QCVL_BRIDGE_DATA_DIR=C:\QuanLyXuong\Data
